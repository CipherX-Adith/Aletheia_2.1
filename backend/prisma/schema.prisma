// This is your Prisma schema file for Aletheia - Trade Finance Platform
// Learn more: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
}

// ─────────────────────────────────────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────────────────────────────────────

enum UserRole {
  PLATFORM_ADMIN
  ORG_ADMIN
  ORG_MEMBER
  VERIFIER
}

enum OrgType {
  EXPORTER
  BUYER
  INVESTOR
  BANK
  NBFC
  INSURER
  LOGISTICS
  EXPORT_COUNCIL
}

enum VerificationStatus {
  PENDING
  UNDER_REVIEW
  INFO_REQUESTED
  APPROVED
  REJECTED
}

enum PassportStatus {
  DRAFT
  ACTIVE
  SUSPENDED
  REVOKED
}

enum ReceivableStatus {
  DRAFT
  SUBMITTED
  UNDER_VERIFICATION
  VERIFIED
  TOKENIZED
  LISTED
  FUNDED
  SETTLED
  DEFAULTED
  CANCELLED
}

enum DocumentType {
  COMMERCIAL_INVOICE
  PURCHASE_ORDER
  BILL_OF_LADING
  SHIPPING_BILL
  PACKING_LIST
  INSURANCE_CERTIFICATE
  LETTER_OF_CREDIT
  BANK_GUARANTEE
  KYB_DOCUMENT
  OTHER
}

enum InvestmentStatus {
  PENDING
  ACTIVE
  SETTLED
  DEFAULTED
  CANCELLED
}

enum SettlementStatus {
  INITIATED
  PROCESSING
  CONFIRMED
  DISTRIBUTED
  FAILED
}

enum ListingStatus {
  ACTIVE
  FUNDED
  EXPIRED
  CANCELLED
}

enum NotificationType {
  KYB_APPROVED
  KYB_REJECTED
  KYB_INFO_REQUESTED
  RECEIVABLE_VERIFIED
  RECEIVABLE_LISTED
  INVESTMENT_RECEIVED
  RECEIVABLE_FUNDED
  SETTLEMENT_INITIATED
  SETTLEMENT_COMPLETED
  GENERAL
}

enum Currency {
  USD
  EUR
  GBP
  INR
  AED
  SGD
}

// ─────────────────────────────────────────────────────────────────────────────
// USERS & ORGANIZATIONS
// ─────────────────────────────────────────────────────────────────────────────

model User {
  id                String    @id @default(cuid())
  email             String    @unique
  passwordHash      String
  firstName         String
  lastName          String
  role              UserRole  @default(ORG_MEMBER)
  isActive          Boolean   @default(true)
  isEmailVerified   Boolean   @default(false)
  emailVerifyToken  String?
  passwordResetToken String?
  passwordResetExpiry DateTime?
  lastLoginAt       DateTime?
  organizationId    String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  organization      Organization?         @relation(fields: [organizationId], references: [id])
  memberships       OrganizationMember[]
  notifications     Notification[]
  aiConversations   AIConversation[]
  auditLogs         AuditLog[]

  @@index([email])
  @@index([organizationId])
}

model Organization {
  id                String    @id @default(cuid())
  name              String
  legalName         String
  registrationNumber String?
  taxId             String?
  orgType           OrgType
  country           String
  state             String?
  city              String?
  address           String?
  website           String?
  phone             String?
  email             String?
  description       String?
  logoUrl           String?
  isActive          Boolean   @default(true)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  users             User[]
  members           OrganizationMember[]
  tradePassport     TradePassport?
  wallet            Wallet?
  receivables       Receivable[]        @relation("ExporterReceivables")
  buyerReceivables  Receivable[]        @relation("BuyerReceivables")
  investments       Investment[]
  verificationRequests VerificationRequest[]
  riskScores        RiskScore[]
  notifications     Notification[]
  auditLogs         AuditLog[]

  @@index([orgType])
}

model OrganizationMember {
  id             String   @id @default(cuid())
  userId         String
  organizationId String
  role           UserRole @default(ORG_MEMBER)
  isActive       Boolean  @default(true)
  joinedAt       DateTime @default(now())

  user           User         @relation(fields: [userId], references: [id])
  organization   Organization @relation(fields: [organizationId], references: [id])

  @@unique([userId, organizationId])
}

// ─────────────────────────────────────────────────────────────────────────────
// TRADE PASSPORT
// ─────────────────────────────────────────────────────────────────────────────

model TradePassport {
  id                String        @id @default(cuid())
  organizationId    String        @unique
  passportNumber    String        @unique @default(cuid())
  status            PassportStatus @default(DRAFT)
  kybStatus         VerificationStatus @default(PENDING)
  trustScore        Float         @default(0)
  reputationScore   Float         @default(0)
  tradeVolume       Float         @default(0)   // total USD traded
  successfulTrades  Int           @default(0)
  defaultCount      Int           @default(0)
  avgSettlementDays Float?
  certifications    String?
  activeSince       DateTime?
  expiresAt         DateTime?
  issuedAt          DateTime?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  organization      Organization  @relation(fields: [organizationId], references: [id])
  tradeHistory      TradePassportEvent[]

  @@index([status])
}

model TradePassportEvent {
  id              String        @id @default(cuid())
  tradePassportId String
  eventType       String
  description     String
  metadata        Json?
  createdAt       DateTime      @default(now())

  tradePassport   TradePassport @relation(fields: [tradePassportId], references: [id])
}

// ─────────────────────────────────────────────────────────────────────────────
// WALLET
// ─────────────────────────────────────────────────────────────────────────────

model Wallet {
  id             String   @id @default(cuid())
  organizationId String   @unique
  publicKey      String   @unique
  // Secret key is NEVER stored. Only the public key.
  network        String   @default("testnet")
  usdcBalance    Float    @default(0)
  xlmBalance     Float    @default(0)
  isActive       Boolean  @default(true)
  lastSyncedAt   DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization   Organization @relation(fields: [organizationId], references: [id])
  transactions   WalletTransaction[]

  @@index([publicKey])
}

model WalletTransaction {
  id          String   @id @default(cuid())
  walletId    String
  txHash      String?  @unique
  type        String   // SEND, RECEIVE, FUND, SETTLEMENT
  amount      Float
  asset       String   @default("USDC")
  fromAddress String?
  toAddress   String?
  memo        String?
  status      String   @default("PENDING")
  createdAt   DateTime @default(now())

  wallet      Wallet   @relation(fields: [walletId], references: [id])

  @@index([walletId])
  @@index([txHash])
}

// ─────────────────────────────────────────────────────────────────────────────
// RECEIVABLES
// ─────────────────────────────────────────────────────────────────────────────

model Receivable {
  id                String           @id @default(cuid())
  receivableNumber  String           @unique @default(cuid())
  exporterId        String
  buyerId           String?
  status            ReceivableStatus @default(DRAFT)
  invoiceNumber     String
  invoiceDate       DateTime
  dueDate           DateTime
  currency          Currency         @default(USD)
  totalAmount       Float
  discountRate      Float?           // offered discount %
  fundingAmount     Float?           // amount after discount
  commodity         String
  originCountry     String
  destinationCountry String
  incoterms         String?          // FOB, CIF, etc.
  buyerName         String
  buyerCountry      String
  description       String?
  ipfsHash          String?          // IPFS CID for document bundle
  submittedAt       DateTime?
  verifiedAt        DateTime?
  tokenizedAt       DateTime?
  fundedAt          DateTime?
  settledAt         DateTime?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  exporter          Organization     @relation("ExporterReceivables", fields: [exporterId], references: [id])
  buyer             Organization?    @relation("BuyerReceivables", fields: [buyerId], references: [id])
  documents         ReceivableDocument[]
  verificationRequest VerificationRequest?
  rwtToken          RWTToken?
  listing           ExchangeListing?
  investments       Investment[]
  settlement        Settlement?
  riskScore         RiskScore?

  @@index([exporterId])
  @@index([status])
  @@index([dueDate])
}

model ReceivableDocument {
  id           String       @id @default(cuid())
  receivableId String
  documentType DocumentType
  fileName     String
  fileUrl      String
  ipfsHash     String?
  mimeType     String?
  fileSizeBytes Int?
  uploadedAt   DateTime     @default(now())
  verifiedAt   DateTime?
  isVerified   Boolean      @default(false)

  receivable   Receivable   @relation(fields: [receivableId], references: [id])

  @@index([receivableId])
}

// ─────────────────────────────────────────────────────────────────────────────
// VERIFICATION
// ─────────────────────────────────────────────────────────────────────────────

model VerificationRequest {
  id             String             @id @default(cuid())
  organizationId String
  receivableId   String?            @unique
  type           String             // KYB, RECEIVABLE
  status         VerificationStatus @default(PENDING)
  assignedTo     String?            // verifier user id
  notes          String?
  rejectionReason String?
  requestedInfoAt DateTime?
  reviewedAt     DateTime?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  organization   Organization       @relation(fields: [organizationId], references: [id])
  receivable     Receivable?        @relation(fields: [receivableId], references: [id])
  steps          VerificationStep[]

  @@index([status])
  @@index([organizationId])
}

model VerificationStep {
  id                    String              @id @default(cuid())
  verificationRequestId String
  stepName              String
  status                VerificationStatus  @default(PENDING)
  notes                 String?
  completedAt           DateTime?
  createdAt             DateTime            @default(now())

  verificationRequest   VerificationRequest @relation(fields: [verificationRequestId], references: [id])
}

// ─────────────────────────────────────────────────────────────────────────────
// RWT TOKENIZATION
// ─────────────────────────────────────────────────────────────────────────────

model RWTToken {
  id              String   @id @default(cuid())
  receivableId    String   @unique
  assetCode       String   // e.g. RWT001
  assetIssuer     String   // Stellar public key of issuer
  totalSupply     Float    // total tokens minted
  availableSupply Float    // tokens still available
  tokenPrice      Float    // USDC per token
  stellarAssetId  String?  // Stellar asset identifier
  mintTxHash      String?  // Stellar transaction hash for minting
  burnTxHash      String?  // Stellar transaction hash for burning
  isActive        Boolean  @default(true)
  mintedAt        DateTime?
  burntAt         DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  receivable      Receivable @relation(fields: [receivableId], references: [id])

  @@index([assetCode])
}

// ─────────────────────────────────────────────────────────────────────────────
// EXCHANGE (MARKETPLACE)
// ─────────────────────────────────────────────────────────────────────────────

model ExchangeListing {
  id             String        @id @default(cuid())
  receivableId   String        @unique
  status         ListingStatus @default(ACTIVE)
  targetAmount   Float
  raisedAmount   Float         @default(0)
  minInvestment  Float         @default(100)
  maxInvestment  Float?
  yieldRate      Float         // APR %
  maturityDate   DateTime
  listedAt       DateTime      @default(now())
  expiresAt      DateTime?
  closedAt       DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  receivable     Receivable    @relation(fields: [receivableId], references: [id])
  investments    Investment[]

  @@index([status])
}

// ─────────────────────────────────────────────────────────────────────────────
// INVESTMENT
// ─────────────────────────────────────────────────────────────────────────────

model Investment {
  id              String          @id @default(cuid())
  listingId       String
  investorOrgId   String
  receivableId    String
  amount          Float
  tokensBought    Float
  tokenPrice      Float
  expectedYield   Float
  expectedReturn  Float
  status          InvestmentStatus @default(PENDING)
  stellarTxHash   String?
  investedAt      DateTime        @default(now())
  settledAt       DateTime?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  listing         ExchangeListing @relation(fields: [listingId], references: [id])
  investorOrg     Organization    @relation(fields: [investorOrgId], references: [id])
  receivable      Receivable      @relation(fields: [receivableId], references: [id])
  distributions   SettlementDistribution[]

  @@index([investorOrgId])
  @@index([listingId])
}

// ─────────────────────────────────────────────────────────────────────────────
// SETTLEMENT
// ─────────────────────────────────────────────────────────────────────────────

model Settlement {
  id              String          @id @default(cuid())
  receivableId    String          @unique
  status          SettlementStatus @default(INITIATED)
  totalAmount     Float
  platformFee     Float
  netAmount       Float
  stellarTxHash   String?
  initiatedAt     DateTime        @default(now())
  confirmedAt     DateTime?
  distributedAt   DateTime?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  receivable      Receivable      @relation(fields: [receivableId], references: [id])
  distributions   SettlementDistribution[]

  @@index([status])
}

model SettlementDistribution {
  id           String     @id @default(cuid())
  settlementId String
  investmentId String
  amount       Float
  principal    Float
  yield        Float
  stellarTxHash String?
  distributedAt DateTime?
  createdAt    DateTime   @default(now())

  settlement   Settlement @relation(fields: [settlementId], references: [id])
  investment   Investment @relation(fields: [investmentId], references: [id])
}

// ─────────────────────────────────────────────────────────────────────────────
// RISK & AI
// ─────────────────────────────────────────────────────────────────────────────

model RiskScore {
  id             String   @id @default(cuid())
  organizationId String?
  receivableId   String?  @unique
  score          Float    // 0-100 (100 = lowest risk)
  rating         String   // AAA, AA, A, BBB, BB, B, C
  factors        Json?    // breakdown of risk factors
  aiAnalysis     String?
  validUntil     DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization   Organization? @relation(fields: [organizationId], references: [id])
  receivable     Receivable?   @relation(fields: [receivableId], references: [id])
}

model AIConversation {
  id        String        @id @default(cuid())
  userId    String
  title     String?
  messages  AIMessage[]
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  user      User          @relation(fields: [userId], references: [id])
}

model AIMessage {
  id             String         @id @default(cuid())
  conversationId String
  role           String         // user | assistant
  content        String
  metadata       Json?
  createdAt      DateTime       @default(now())

  conversation   AIConversation @relation(fields: [conversationId], references: [id])
}

// ─────────────────────────────────────────────────────────────────────────────
// NOTIFICATIONS & AUDIT
// ─────────────────────────────────────────────────────────────────────────────

model Notification {
  id             String           @id @default(cuid())
  userId         String
  organizationId String?
  type           NotificationType
  title          String
  message        String
  isRead         Boolean          @default(false)
  metadata       Json?
  createdAt      DateTime         @default(now())

  user           User             @relation(fields: [userId], references: [id])
  organization   Organization?    @relation(fields: [organizationId], references: [id])

  @@index([userId, isRead])
}

model AuditLog {
  id             String   @id @default(cuid())
  userId         String?
  organizationId String?
  action         String
  resource       String
  resourceId     String?
  changes        Json?
  ipAddress      String?
  userAgent      String?
  createdAt      DateTime @default(now())

  user           User?        @relation(fields: [userId], references: [id])
  organization   Organization? @relation(fields: [organizationId], references: [id])

  @@index([userId])
  @@index([resource, resourceId])
  @@index([createdAt])
}
